# Project Akshara: Environment Variables (TEMPLATE)
# ==================================================
# 1. Copy this file to .env
# 2. Replace placeholders with your actual keys
# 3. NEVER commit .env to version control
#
# This .env.example file is a TEMPLATE - do not put real keys here!

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Claude/Anthropic API Key (optional)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Moonshot / Kimi API Key (optional, for shadow/challenger assembly model)
# Get yours at: https://platform.moonshot.ai/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Optional Moonshot base URL override (defaults to official OpenAI-compatible endpoint)
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Optional: Google Cloud Project (for Vertex AI)
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=global

# Optional: Use Vertex AI instead of Gemini Developer API
# GOOGLE_GENAI_USE_VERTEXAI=false

# Logging level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Output directory (relative to project root)
OUTPUT_DIR=./output
